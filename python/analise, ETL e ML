        "\n",
        "print(f\"Treino: {X_train.shape[0]} registros\")\n",
        "print(f\"Teste:  {X_test.shape[0]} registros\")\n",
        "\n",
        "modelo = RandomForestClassifier(n_estimators=100, random_state=42)\n",
        "modelo.fit(X_train, y_train)\n",
        "\n",
